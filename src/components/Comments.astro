---
/*
 * Giscus comments component
 *
 * SETUP (one time, after pushing to GitHub):
 * 1. Go to https://giscus.app
 * 2. Enter your repo (e.g. raymond/ai-experts)
 * 3. Pick category mapping: "Discussion title contains page <title>"
 * 4. Pick category: "Announcements" (create it as a Discussion category first)
 * 5. Copy the data-repo-id and data-category-id values shown
 * 6. Paste them into the two TODO fields below
 */
---

<section class="comments">
  <div class="comments-header">
    <span class="eyebrow">// discussion</span>
    <h3>Comments</h3>
    <p class="comments-note">Replies use GitHub Discussions. You'll need a GitHub account to post.</p>
  </div>

  <script
    src="https://giscus.app/client.js"
    data-repo="YOUR_GITHUB_USERNAME/ai-experts"
    data-repo-id="TODO_PASTE_REPO_ID_HERE"
    data-category="Announcements"
    data-category-id="TODO_PASTE_CATEGORY_ID_HERE"
    data-mapping="title"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="en"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  .comments-header {
    margin-bottom: 1.5rem;
  }

  .comments-header h3 {
    margin: 0.4rem 0 0.4rem;
    font-size: 1.5rem;
  }

  .comments-note {
    color: var(--color-ink-mute);
    font-size: 0.9rem;
    margin: 0;
  }
</style>
