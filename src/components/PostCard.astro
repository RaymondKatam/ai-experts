---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
}

const { href, title, description, pubDate, category, tags } = Astro.props;

const dateFmt = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryLabel: Record<string, string> = {
  ai: 'AI',
  infra: 'Infra',
  homelab: 'Homelab',
  notes: 'Notes',
  tutorial: 'Tutorial',
};
---

<article class="post-card">
  <a href={href} class="card-link">
    <header class="card-head">
      <span class="card-category mono">{categoryLabel[category] ?? category}</span>
      <time class="card-date mono" datetime={pubDate.toISOString()}>{dateFmt}</time>
    </header>

    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>

    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 4).map(t => <span class="tag mono">#{t}</span>)}
      </div>
    )}

    <span class="card-arrow" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M5 9H13M13 9L9 5M13 9L9 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    transition: all 0.25s var(--ease);
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--color-blue-bright);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.3s var(--ease);
  }

  .post-card:hover {
    border-color: var(--color-blue-bright);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .post-card:hover::before {
    transform: scaleY(1);
  }

  .card-link {
    display: block;
    padding: 1.5rem 1.75rem;
    color: inherit;
    text-decoration: none;
    position: relative;
  }

  .card-link:hover {
    text-decoration: none;
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.85rem;
    font-size: 0.72rem;
  }

  .card-category {
    color: var(--color-blue-bright);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .card-date {
    color: var(--color-ink-mute);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.3;
    margin: 0 0 0.5rem;
    color: var(--color-ink);
    transition: color 0.2s var(--ease);
  }

  .post-card:hover .card-title {
    color: var(--color-blue-deep);
  }

  .card-desc {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 1rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.72rem;
    color: var(--color-ink-mute);
    background: var(--color-blue-tint);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .card-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--color-ink-mute);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.25s var(--ease);
  }

  .post-card:hover .card-arrow {
    color: var(--color-blue-bright);
    opacity: 1;
    transform: translateX(0);
  }
</style>
