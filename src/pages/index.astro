---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.slice(0, 6);
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-meta mono">
        <span class="status-dot"></span>
        <span>node online · last sync {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
      </div>

      <h1 class="hero-title">
        Practical writing on <span class="hl">AI & infrastructure</span>.
      </h1>

      <p class="hero-tag">
        <strong>AI Experts</strong> is a small collective sharing what we learn —
        research notes, model experiments, home lab writeups, and the things
        we break while figuring it all out.
      </p>

      <div class="hero-actions">
        <a href="/blog" class="btn btn-primary">
          Read the posts
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 7H11M11 7L7 3M11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/about" class="btn btn-ghost">About this lab</a>
      </div>

      <!-- Decorative terminal panel -->
      <div class="terminal" aria-hidden="true">
        <div class="terminal-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="terminal-title mono">~/homelab/status</span>
        </div>
        <pre class="terminal-body mono"><span class="prompt">$</span> uptime
<span class="out"> 21 days,  4:17  load average: 0.42, 0.38, 0.31</span>
<span class="prompt">$</span> docker ps --format "{`{`}{`{`}.Names{`}`}{`}`}" | wc -l
<span class="out"> 14</span>
<span class="prompt">$</span> echo "writing about it →"
<span class="out"> writing about it →</span>
<span class="cursor">▌</span></pre>
      </div>
    </div>
  </section>

  <!-- DEDICATION -->
  <section class="dedication">
    <div class="container">
      <figure class="dedication-card">
        <span class="dedication-mark" aria-hidden="true">"</span>
        <blockquote class="dedication-text">
          These posts are dedicated to every learner who is studying AI not because they had to, but because they chose to.
        </blockquote>
        <figcaption class="dedication-sig mono">— Raymond Kipngetich</figcaption>
      </figure>
    </div>
  </section>

  <!-- RECENT POSTS -->
  <section class="recent">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">// recent entries</span>
          <h2>Latest from the lab</h2>
        </div>
        <a href="/blog" class="view-all">
          View all posts
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 8H12M12 8L8 4M12 8L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      {featured.length === 0 ? (
        <div class="empty">
          <p>No posts yet. Drop a <code>.md</code> file in <code>src/content/blog/</code> to get started.</p>
        </div>
      ) : (
        <div class="post-grid">
          {featured.map(post => (
            <PostCard
              href={`/blog/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 4rem 0 5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-blue-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 920px;
  }

  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--color-ink-mute);
    background: var(--color-paper);
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    margin-bottom: 1.75rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5); }
    70% { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .hl {
    color: var(--color-blue-bright);
    position: relative;
    white-space: nowrap;
  }

  .hl::after {
    content: '';
    position: absolute;
    bottom: 0.1em;
    left: 0;
    right: 0;
    height: 0.18em;
    background: var(--color-blue-glow);
    z-index: -1;
  }

  .hero-tag {
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    max-width: 620px;
    margin-bottom: 2rem;
  }

  .hero-tag strong {
    color: var(--color-blue-deep);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.2s var(--ease);
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--color-blue-bright);
    color: white;
    box-shadow: var(--shadow-blue);
  }

  .btn-primary:hover {
    background: var(--color-blue-deep);
    color: white;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-ink-soft);
    border-color: var(--color-line);
  }

  .btn-ghost:hover {
    color: var(--color-blue-deep);
    border-color: var(--color-blue-bright);
    background: var(--color-paper);
    text-decoration: none;
  }

  /* Terminal */
  .terminal {
    background: var(--color-blue-deep);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-blue);
    max-width: 600px;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .terminal-bar .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }

  .terminal-bar .dot:nth-child(1) { background: #ff5f56; }
  .terminal-bar .dot:nth-child(2) { background: #ffbd2e; }
  .terminal-bar .dot:nth-child(3) { background: #27c93f; }

  .terminal-title {
    color: rgba(255, 255, 255, 0.5);
    margin-left: auto;
    font-size: 0.75rem;
  }

  .terminal-body {
    padding: 1rem 1.2rem;
    font-size: 0.82rem;
    line-height: 1.7;
    color: #e2e8f0;
    margin: 0;
    overflow-x: auto;
  }

  .prompt { color: #60a5fa; user-select: none; margin-right: 0.5rem; }
  .out { color: #94a3b8; }
  .cursor {
    color: #60a5fa;
    animation: blink 1.1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Dedication */
  .dedication {
    padding: 1rem 0 3rem;
  }

  .dedication-card {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-blue-bright);
    border-radius: var(--radius-lg);
    position: relative;
    text-align: center;
  }

  .dedication-mark {
    position: absolute;
    top: -0.5rem;
    left: 1.5rem;
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-blue-bright);
    background: var(--color-bg);
    padding: 0 0.5rem;
    user-select: none;
  }

  .dedication-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-ink);
    font-style: italic;
    margin: 0 0 1.25rem;
    border: none;
    padding: 0;
    background: transparent;
  }

  .dedication-sig {
    font-size: 0.85rem;
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .dedication-card { padding: 2rem 1.25rem; }
    .dedication-text { font-size: 1.1rem; }
  }

  /* Recent posts */
  .recent {
    padding: 2rem 0 4rem;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  .section-head h2 {
    margin: 0.3rem 0 0;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: var(--color-blue-bright);
    font-weight: 500;
    white-space: nowrap;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  .empty {
    text-align: center;
    padding: 3rem;
    background: var(--color-paper);
    border: 1px dashed var(--color-line);
    border-radius: var(--radius-lg);
    color: var(--color-ink-mute);
  }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 0 3.5rem; }
    .terminal-body { font-size: 0.75rem; }
    .section-head { flex-direction: column; align-items: flex-start; }
  }
</style>
